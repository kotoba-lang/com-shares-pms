// Shares_pms clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace shares_pms {

    entity Flight {
        id: string @unique
        carrier: string
        number: string
        origin: string
        destination: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Booking {
        id: string @unique
        pnr: string
        passengerName: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Segment {
        id: string @unique
        bookingId: string
        flightId: string
        cabin: string
        seat: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Property {
        id: string @unique
        name: string
        location: string
        rooms: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Reservation {
        id: string @unique
        propertyId: string
        guestName: string
        checkIn: datetime
        nights: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Fare {
        id: string @unique
        flightId: string
        cabin: string
        price: float
        currency: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
